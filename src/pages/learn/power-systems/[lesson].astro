---
// src/pages/learn/power-systems/[lesson].astro — Individual power systems lesson page.

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import TutorialStepper from '../../../components/simulators/circuit/TutorialStepper.astro';
import PowerFlowSimulator from '../../../components/simulators/power/PowerFlowSimulator';
import ConvergenceChart from '../../../components/simulators/power/ConvergenceChart';
import PerUnitConverter from '../../../components/simulators/power/PerUnitConverter';
import { internalHref } from '../../../utils/url';
import type { LessonBase } from '../../../lib/learn/types';
import type { PowerNetwork } from '../../../lib/power/types';

export async function getStaticPaths() {
  const lessonModules = import.meta.glob<LessonBase>(
    '../../../data/power-systems/*.json',
    { eager: true }
  );

  // Load all network JSON files eagerly at build time
  const networkModules = import.meta.glob<PowerNetwork>(
    '../../../data/power-networks/**/*.json',
    { eager: true }
  );

  return Object.values(lessonModules).map(lesson => {
    const sp = lesson.simulatorProps as Record<string, unknown>;
    const networkId = sp['networkId'] as string | undefined;

    // Match network by its id field (not filename)
    const network = networkId
      ? (Object.values(networkModules).find((n: unknown) => (n as PowerNetwork).id === networkId) as PowerNetwork | undefined)
      : undefined;

    return {
      params: { lesson: lesson.id },
      props: { lesson, network: network ?? null },
    };
  });
}

interface Props {
  lesson: LessonBase;
  network: PowerNetwork | null;
}

const { lesson, network } = Astro.props;
const sp = lesson.simulatorProps as Record<string, unknown>;
const faultBus = sp['faultBus'] as number | undefined;
---

<Layout
  title={lesson.title}
  description={lesson.description}
  needsKatex={false}
>
  <Header />
  <main id="main-content">
    <div class="container py-16">

      <!-- Breadcrumb -->
      <nav class="lesson-breadcrumb" aria-label="Breadcrumb">
        <a href={internalHref('learn/power-systems')}>Power Systems Lessons</a>
        <span aria-hidden="true"> / </span>
        <span>{lesson.title}</span>
      </nav>

      <!-- Header -->
      <div class="lesson-header">
        <div class="lesson-header__meta">
          <span class={`lesson-badge lesson-badge--${lesson.difficulty}`}>
            {lesson.difficulty}
          </span>
          <span class="lesson-badge lesson-badge--domain">Power Systems</span>
        </div>
        <h1 class="lesson-title">{lesson.title}</h1>
        <p class="lesson-desc">{lesson.description}</p>
      </div>

      <!-- Main content -->
      <div class="lesson-layout">

        <!-- Simulator column -->
        <div class="lesson-simulator">
          {lesson.simulator === 'power-flow' && network && (
            <PowerFlowSimulator network={network} client:visible />
          )}
          {lesson.simulator === 'fault-analysis' && network && (
            <PowerFlowSimulator
              network={network}
              mode="fault"
              faultBus={faultBus}
              client:visible
            />
          )}
          {lesson.simulator === 'algorithm-comparison' && network && (
            <ConvergenceChart network={network} client:visible />
          )}
          {lesson.simulator === 'per-unit' && (
            <PerUnitConverter client:idle />
          )}
          {!['power-flow','fault-analysis','algorithm-comparison','per-unit'].includes(lesson.simulator) && (
            <div class="simulator-placeholder">
              <span>Simulator: <code>{lesson.simulator}</code></span>
            </div>
          )}
        </div>

        <!-- Tutorial column -->
        <div class="lesson-tutorial">
          <TutorialStepper
            steps={lesson.tutorial.steps}
            lessonId={lesson.id}
          />
        </div>

      </div>

      <!-- Footer nav -->
      <div class="lesson-footer-nav">
        <a href={internalHref('learn/power-systems')} class="btn">
          ← All power systems lessons
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .lesson-breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .lesson-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lesson-breadcrumb a:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .lesson-header {
    margin-bottom: 2rem;
  }

  .lesson-header__meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .lesson-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
  }

  .lesson-badge--beginner     { background: color-mix(in srgb, var(--color-pcb) 15%, transparent); color: var(--color-pcb-light); }
  .lesson-badge--intermediate { background: color-mix(in srgb, var(--color-copper) 15%, transparent); color: var(--color-copper); }
  .lesson-badge--advanced     { background: color-mix(in srgb, #2563eb 15%, transparent); color: #60a5fa; }
  .lesson-badge--domain       { background: var(--color-bg-grid); color: var(--color-text-muted); border: 1px solid var(--color-border); }

  .lesson-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .lesson-desc {
    color: var(--color-text-muted);
    max-width: 56ch;
    line-height: 1.6;
    margin: 0;
  }

  .lesson-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (width >= 1024px) {
    .lesson-layout {
      grid-template-columns: 1fr 380px;
      align-items: start;
    }
  }

  .lesson-footer-nav {
    margin-top: 2.5rem;
  }

  .simulator-placeholder {
    padding: 2rem;
    border: 1px dashed var(--color-border);
    border-radius: 4px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-align: center;
  }
</style>
