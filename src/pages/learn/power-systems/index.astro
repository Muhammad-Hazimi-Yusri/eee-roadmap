---
// src/pages/learn/power-systems/index.astro — Power Systems lesson browser

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { internalHref } from '../../../utils/url';
import type { LessonBase } from '../../../lib/learn/types';

const lessonModules = import.meta.glob<LessonBase>(
  '../../../data/power-systems/*.json',
  { eager: true }
);

const difficultyOrder: Record<string, number> = { beginner: 0, intermediate: 1, advanced: 2 };

const lessons = Object.values(lessonModules).sort(
  (a, b) => difficultyOrder[a.difficulty] - difficultyOrder[b.difficulty]
);
---

<Layout
  title="Power Systems Analysis Lessons"
  description="Interactive power systems tutorials — Newton-Raphson power flow, per-unit system, fault analysis, and algorithm comparison with a browser-based TypeScript solver."
  needsKatex={false}
>
  <Header />
  <main id="main-content">
    <div class="container py-16">
      <p class="font-mono text-xs uppercase tracking-widest text-muted mb-2">// phase 3</p>
      <h1 class="text-2xl sm:text-3xl mb-2">Power Systems Analysis</h1>
      <p class="max-w-xl text-muted mb-10">
        Browser-based power flow analysis — Newton-Raphson and Gauss-Seidel solvers, single-line
        diagrams, voltage profiles, and fault calculations using a TypeScript implementation
        validated against the IEEE 14-bus benchmark.
      </p>

      <div class="lesson-grid">
        {lessons.map(lesson => (
          <a
            href={internalHref(`learn/power-systems/${lesson.id}`)}
            class={`lesson-card lesson-card--${lesson.difficulty}`}
          >
            <span class="lesson-card__badge">{lesson.difficulty}</span>
            <h2 class="lesson-card__title">{lesson.title}</h2>
            <p class="lesson-card__desc">{lesson.description}</p>
            <span class="lesson-card__steps">{lesson.tutorial.steps.length} steps</span>
          </a>
        ))}
      </div>

      <div class="playground-link">
        <a href={internalHref('learn/power-systems/playground')} class="btn">
          Open JupyterLite Playground →
        </a>
        <span class="playground-note">
          Full pandapower in-browser via Pyodide (30–80 MB download)
        </span>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .lesson-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-bg);
    transition: border-color 0.15s, background 0.15s;
  }

  .lesson-card:hover {
    border-color: #2563eb;
    background: var(--color-bg-grid);
  }

  .lesson-card__badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 0.6rem;
  }

  .lesson-card--beginner     .lesson-card__badge { background: color-mix(in srgb, var(--color-pcb) 15%, transparent); color: var(--color-pcb-light); }
  .lesson-card--intermediate .lesson-card__badge { background: color-mix(in srgb, var(--color-copper) 15%, transparent); color: var(--color-copper); }
  .lesson-card--advanced     .lesson-card__badge { background: color-mix(in srgb, #2563eb 15%, transparent); color: #60a5fa; }

  .lesson-card__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }

  .lesson-card__desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .lesson-card__steps {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .playground-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .playground-note {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }
</style>
