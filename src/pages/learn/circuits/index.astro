---
// Redirects to /labs/#circuits — Labs is the unified lesson browser.
const { BASE_URL } = import.meta.env;
const dest = `${BASE_URL}labs/#circuits`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <title>Redirecting to Labs…</title>
  </head>
  <body>
    <p>Redirecting to <a href={dest}>Labs</a>…</p>
  </body>
</html>
