---
// src/pages/learn/circuits/index.astro — Circuit lesson browser

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { internalHref } from '../../../utils/url';
import type { CircuitLesson } from '../../../lib/circuit/types';

// Load all circuit lesson JSON files at build time
const lessonModules = import.meta.glob<CircuitLesson>(
  '../../../data/circuits/**/*.json',
  { eager: true }
);

// Group lessons by category, preserving insertion order
const byCategory: Record<string, { lesson: CircuitLesson; path: string }[]> = {};
for (const [path, lesson] of Object.entries(lessonModules)) {
  // path looks like: ../../../data/circuits/fundamentals/ohms-law.json
  if (path.includes('/_schema/')) continue; // skip schema file
  const cat = lesson.category;
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push({ lesson, path });
}

const categoryLabels: Record<string, string> = {
  'fundamentals':      'Fundamentals',
  'rc-rl-rlc':         'RC / RL / RLC',
  'diodes':            'Diodes',
  'op-amps':           'Op-Amps',
  'transistors':       'Transistors',
  'digital':           'Digital Logic',
  'power-electronics': 'Power Electronics',
};

const difficultyOrder: Record<string, number> = {
  beginner: 0, intermediate: 1, advanced: 2,
};
---

<Layout
  title="Circuit Lessons"
  description="Interactive circuit tutorials with step-by-step walkthroughs and live simulation."
  needsKatex={false}
>
  <Header />
  <main id="main-content">
    <div class="container py-16">
      <p class="font-mono text-xs uppercase tracking-widest text-muted mb-2">
        // interactive
      </p>
      <h1 class="text-2xl sm:text-3xl mb-2">Circuit Lessons</h1>
      <p class="max-w-xl text-muted mb-10">
        Step-by-step circuit tutorials with live Falstad simulation.
        Work through the steps, adjust component values, and verify your understanding.
      </p>

      {Object.entries(byCategory).map(([cat, entries]) => {
        const sorted = [...entries].sort(
          (a, b) => difficultyOrder[a.lesson.difficulty] - difficultyOrder[b.lesson.difficulty]
        );
        return (
          <section class="circuit-category">
            <h2 class="circuit-category__title">
              {categoryLabels[cat] ?? cat}
            </h2>
            <div class="circuit-grid">
              {sorted.map(({ lesson }) => (
                <a
                  href={internalHref(`learn/circuits/${lesson.category}/${lesson.id}`)}
                  class={`circuit-card circuit-card--${lesson.difficulty}`}
                >
                  <span class="circuit-card__badge">{lesson.difficulty}</span>
                  <h3 class="circuit-card__title">{lesson.title}</h3>
                  <p class="circuit-card__desc">{lesson.description}</p>
                  <span class="circuit-card__steps">
                    {lesson.tutorial.steps.length} steps
                  </span>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .circuit-category {
    margin-bottom: 2.5rem;
  }

  .circuit-category__title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .circuit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .circuit-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-bg);
    transition: border-color 0.15s, background 0.15s;
    position: relative;
  }

  .circuit-card:hover {
    border-color: var(--color-copper);
    background: var(--color-bg-grid);
  }

  .circuit-card__badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 0.6rem;
  }

  .circuit-card--beginner     .circuit-card__badge { background: color-mix(in srgb, var(--color-pcb) 15%, transparent); color: var(--color-pcb-light); }
  .circuit-card--intermediate .circuit-card__badge { background: color-mix(in srgb, var(--color-copper) 15%, transparent); color: var(--color-copper); }
  .circuit-card--advanced     .circuit-card__badge { background: color-mix(in srgb, #a64ca6 15%, transparent); color: #c87dc8; }

  .circuit-card__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }

  .circuit-card__desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .circuit-card__steps {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }
</style>
