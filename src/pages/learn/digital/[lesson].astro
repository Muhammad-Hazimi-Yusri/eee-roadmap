---
// src/pages/learn/digital/[lesson].astro — Individual digital lesson page.

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import TutorialStepper from '../../../components/simulators/circuit/TutorialStepper.astro';
import WaveDromDiagram from '../../../components/simulators/digital/WaveDromDiagram.astro';
import CircuitVerseEmbed from '../../../components/simulators/digital/CircuitVerseEmbed.astro';
import TruthTableGenerator from '../../../components/simulators/digital/TruthTableGenerator';
import VerilogPlayground from '../../../components/simulators/digital/VerilogPlayground';
import { internalHref } from '../../../utils/url';
import type { LessonBase } from '../../../lib/learn/types';

export async function getStaticPaths() {
  const modules = import.meta.glob<LessonBase>(
    '../../../data/digital/*.json',
    { eager: true }
  );

  return Object.values(modules).map(lesson => ({
    params: { lesson: lesson.id },
    props: { lesson },
  }));
}

interface Props {
  lesson: LessonBase;
}

const { lesson } = Astro.props;

const sp = lesson.simulatorProps as Record<string, unknown>;
const waveSource = (sp['source'] as string) ?? '';
const waveTitle  = (sp['title']  as string) ?? undefined;
const cvEmbedUrl = (sp['embedUrl'] as string) ?? '';
const cvHeight   = (sp['height'] as number) ?? 600;
---

<Layout
  title={lesson.title}
  description={lesson.description}
  needsKatex={false}
>
  <Header />
  <main id="main-content">
    <div class="container py-16">

      <!-- Breadcrumb -->
      <nav class="lesson-breadcrumb" aria-label="Breadcrumb">
        <a href={internalHref('learn/digital')}>Digital Lessons</a>
        <span aria-hidden="true"> / </span>
        <span>{lesson.title}</span>
      </nav>

      <!-- Header -->
      <div class="lesson-header">
        <div class="lesson-header__meta">
          <span class={`lesson-badge lesson-badge--${lesson.difficulty}`}>
            {lesson.difficulty}
          </span>
          <span class="lesson-badge lesson-badge--domain">Digital Electronics</span>
        </div>
        <h1 class="lesson-title">{lesson.title}</h1>
        <p class="lesson-desc">{lesson.description}</p>
      </div>

      <!-- Main content -->
      <div class="lesson-layout">

        <!-- Simulator column -->
        <div class="lesson-simulator">
          {lesson.simulator === 'wavedrom' && (
            <WaveDromDiagram source={waveSource} title={waveTitle} />
          )}
          {lesson.simulator === 'circuitverse' && (
            <CircuitVerseEmbed embedUrl={cvEmbedUrl} height={cvHeight} />
          )}
          {lesson.simulator === 'truth-table' && (
            <TruthTableGenerator client:idle />
          )}
          {lesson.simulator === 'verilog' && (
            <VerilogPlayground client:visible />
          )}
        </div>

        <!-- Tutorial column -->
        <div class="lesson-tutorial">
          <TutorialStepper
            steps={lesson.tutorial.steps}
            lessonId={lesson.id}
          />
        </div>

      </div>

      <!-- Related roadmap topics -->
      {lesson.relatedConcepts && lesson.relatedConcepts.length > 0 && (
        <div class="related-concepts">
          <span class="related-concepts__label">Related roadmap topics:</span>
          {lesson.relatedConcepts.map(rc => (
            <a
              href={internalHref(`roadmaps/${rc.trackSlug}#${rc.topicId}`)}
              class="related-concepts__link"
            >
              {rc.label}
            </a>
          ))}
        </div>
      )}

      <!-- Footer nav -->
      <div class="lesson-footer-nav">
        <a href={internalHref('learn/digital')} class="btn">
          ← All digital lessons
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .lesson-breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .lesson-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lesson-breadcrumb a:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .lesson-header {
    margin-bottom: 2rem;
  }

  .lesson-header__meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .lesson-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    display: inline-block;
  }

  .lesson-badge--beginner     { background: color-mix(in srgb, var(--color-pcb) 15%, transparent); color: var(--color-pcb-light); }
  .lesson-badge--intermediate { background: color-mix(in srgb, var(--color-copper) 15%, transparent); color: var(--color-copper); }
  .lesson-badge--advanced     { background: color-mix(in srgb, #a64ca6 15%, transparent); color: #c87dc8; }
  .lesson-badge--domain       { background: var(--color-bg-grid); color: var(--color-text-muted); border: 1px solid var(--color-border); }

  .lesson-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .lesson-desc {
    color: var(--color-text-muted);
    max-width: 56ch;
    line-height: 1.6;
    margin: 0;
  }

  .lesson-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (width >= 1024px) {
    .lesson-layout {
      grid-template-columns: 1fr 380px;
      align-items: start;
    }
  }

  .related-concepts {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .related-concepts__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .related-concepts__link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-copper, #c87533);
    border-radius: 3px;
    color: var(--color-copper, #c87533);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .related-concepts__link:hover {
    background: var(--color-copper, #c87533);
    color: #fff;
  }

  .lesson-footer-nav {
    margin-top: 2.5rem;
  }
</style>
