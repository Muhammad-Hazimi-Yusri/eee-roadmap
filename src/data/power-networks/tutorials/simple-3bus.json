      "baseKV": 132, "position": { "x": 80, "y": 200 }
    },
    {
      "id": 2, "name": "Bus 2 (Gen)",   "type": "PV",
      "Psch": 0.0,  "Qsch": 0.0,  "Vmag": 1.04, "theta": 0,
      "Qmin": -0.5, "Qmax": 0.5,  "Gsh": 0, "Bsh": 0,
      "baseKV": 132, "position": { "x": 300, "y": 200 }
    },
    {
      "id": 3, "name": "Bus 3 (Load)",  "type": "PQ",
      "Psch": 0.0,  "Qsch": 0.0,  "Vmag": 1.0,  "theta": 0,
