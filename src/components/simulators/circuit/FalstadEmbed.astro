---
// src/components/simulators/circuit/FalstadEmbed.astro
//
// Embeds the Falstad CircuitJS1 simulator via iframe.
//
// LICENSING NOTE: CircuitJS1 is GPL-2.0. It is used here exclusively via an
// iframe pointing to the canonical hosted instance at falstad.com. The GPL-2.0
// source is never imported, bundled, or copied into this MIT-licensed project.

interface Props {
  /** Raw Falstad circuit text (the `ctz` URL-parameter format). */
  circuitText: string;
  /** Optional title shown above the embed. */
  title?: string;
  /** Height of the iframe in pixels (default 480). */
  height?: number;
  /** Allow the user to interact with (edit) the circuit in the iframe. Default true. */
  editable?: boolean;
}

const {
  circuitText,
  title,
  height = 480,
  editable = true,
} = Astro.props;

// Encode circuit text for the `ctz` URL parameter.
const ctz = encodeURIComponent(circuitText);

// Build the iframe URL using falstad.com's hosted CircuitJS1 instance.
const params = new URLSearchParams({
  hideMenu: 'true',
  hideSidebar: 'true',
  whiteBackground: 'true',
  ctz,
});
if (!editable) params.set('editable', 'false');

const iframeSrc = `https://www.falstad.com/circuit/circuitjs.html?${params.toString()}`;
---

<div class="falstad-embed">
  {title && <p class="falstad-embed__label">// {title}</p>}

  <div class="falstad-embed__wrapper" style={`height: ${height}px`}>
    <iframe
      src={iframeSrc}
      title={title ?? 'Interactive Circuit Simulator'}
      width="100%"
      height="100%"
      loading="lazy"
      sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>

  <p class="falstad-embed__credit">
    Simulator: <a
      href="https://www.falstad.com/circuit/"
      target="_blank"
      rel="noopener noreferrer"
    >Falstad CircuitJS1</a> (GPL-2.0) — hosted by falstad.com
  </p>
</div>

<style>
  .falstad-embed {
    margin: 1.5rem 0;
  }

  .falstad-embed__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .falstad-embed__wrapper {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
  }

  .falstad-embed__wrapper iframe {
    display: block;
    border: none;
  }

  .falstad-embed__credit {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: 0.375rem;
  }

  .falstad-embed__credit a {
    color: var(--color-text-muted);
    text-decoration: underline;
  }

  .falstad-embed__credit a:hover {
    color: var(--color-text);
  }
</style>
